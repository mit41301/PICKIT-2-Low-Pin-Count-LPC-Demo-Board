                      00020 ; *******************************************************************
                      00021 ; PICkit 2 Lesson 5 - Switch Debounce
                      00022 ;
                      00023 ; This shows one method to debounce switches.  
                      00024 ; Samples the line every 1mS, and waits for 5 in a row before
                      00025 ; acting on the change of state.
                      00026 ;
                      00027 ; *******************************************************************
                      00028 ; * See Low Pin Count Demo Board User's Guide for Lesson Information*
                      00029 ; *******************************************************************
                      00030 ; * NOTE: The PIC16F690 requires the AC162061 header for debugging  *
                      00031 ; *******************************************************************
                      00032      
                      00033 #include <p16F690.inc>
                      00001         LIST
                      00002 ; P16F690.INC  Standard Header File, Version 1.00    Microchip Technology, Inc.
                      00607         LIST
2007   30D4           00034      __config (_INTRC_OSC_NOCLKOUT & _WDT_OFF & _PWRTE_OFF & _MCLRE_OFF & _CP_OFF & _BOR_OFF & _IESO_OFF
                             & _FCMEN_OFF)
                      00035 
                      00036      cblock     0x20
  00000020            00037 Delay               ; Assign an address to label Delay1
  00000021            00038 Display             ; define a variable to hold the diplay
  00000022            00039 LastStableState     ; keep track of switch state (open-1; closed-0)
  00000023            00040 Counter
                      00041      endc
                      00042      
0000                  00043      org 0
0000                  00044 Start:
0000   1683           00045      bsf       STATUS,RP0          ; select Register Page 1
0001   30FF           00046      movlw     0xFF
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0002   0085           00047      movwf     TRISA               ; Make PortA all input
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
MPASM  5.06.4                      DEBOUNCE.ASM   12-18-2006  15:08:53         PAGE  2


LOC  OBJECT CODE     LINE SOURCE TEXT
  VALUE

0003   0187           00048      clrf      TRISC               ; Make PortC all output
                      00049 
0004   1283           00050      bcf       STATUS,RP0          ; address Register Page 2
0005   1703           00051      bsf       STATUS,RP1     
0006   30F7           00052      movlw     0xF7                ; PortA3 pin is digital
Message[302]: Register in operand not in bank 0.  Ensure that bank bits are correct.
0007   009E           00053      movwf     ANSEL
0008   1283           00054      bcf       STATUS,RP0          ; address Register Page 0
0009   1303           00055      bcf       STATUS,RP1
                      00056      
000A   01A1           00057      clrf      Display
000B   0187           00058      clrf      PORTC
000C   3001           00059      movlw     1
000D   00A2           00060      movwf     LastStableState     ; Assume the Switch is up.
000E   01A3           00061      clrf      Counter
000F                  00062 MainLoop:
000F   1822           00063      btfsc     LastStableState,0
0010   2816           00064      goto      LookingForUp
0011                  00065 LookingForDown:
0011   0103           00066      clrw                          ; assume it's not, so clear
0012   1D85           00067      btfss     PORTA,3             ; wait for switch to go low
0013   0A23           00068      incf      Counter,w           ; if it's low, bump the counter
0014   00A3           00069      movwf     Counter             ; store either the 0 or incremented value
0015   281A           00070      goto      EndDebounce
                      00071      
0016                  00072 LookingForUp:
0016   0103           00073      clrw                          ; assume it's not, so clear
0017   1985           00074      btfsc     PORTA,3             ; wait for switch to go low
0018   0A23           00075      incf      Counter,w
0019   00A3           00076      movwf     Counter
                      00077 
001A                  00078 EndDebounce:
001A   0823           00079      movf      Counter,w           ; have we seen 10 in a row?
001B   3A05           00080      xorlw     5
001C   1D03           00081      btfss     STATUS,Z     
001D   2825           00082      goto      Delay1mS
                      00083      
001E   09A2           00084      comf      LastStableState,f   ; after 10 straight, reverse the direction
001F   01A3           00085      clrf      Counter
0020   1C22           00086      btfss     LastStableState,0   ; Was it a key-down press?
0021   2825           00087      goto      Delay1mS            ; no: take no action
                      00088      
0022   0AA1           00089      incf      Display,f           ; if it's the down direction, 
0023   0821           00090      movf      Display,w           ; take action on the switch
0024   0087           00091      movwf     PORTC               ; (increment counter and put on display)
                      00092      
0025                  00093 Delay1mS:
0025   3047           00094      movlw     .71                 ; delay ~1000uS
0026   00A0           00095      movwf     Delay
0027   0BA0           00096      decfsz    Delay,f             ; this loop does 215 cycles
0028   2827           00097      goto      $-1          
0029   0BA0           00098      decfsz    Delay,f             ; This loop does 786 cycles
002A   2829           00099      goto      $-1
