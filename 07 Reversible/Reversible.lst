002A                  00108 LookingFor0:
002A   1985           00109      btfsc     PORTA,3             ; is the switch pressed (0)
002B   2832           00110      goto      Rotate
002C   1424           00111      bsf       LookingFor,0        ; yes  Next we'll be looking for a 1
002D   30FF           00112      movlw     0xFF                ; load the W register incase we need it
002E   06A3           00113      xorwf     Direction,f         ; yes, flip the direction bit
002F   2832           00114      goto      Rotate
