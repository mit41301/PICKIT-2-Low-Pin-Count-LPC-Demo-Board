0035                  00124 RotateRight:
0035   0CA2           00125      rrf       Display,f
0036   1803           00126      btfsc     STATUS,C            ; Did the bit rotate into the carry?
0037   15A2           00127      bsf       Display,3           ; yes, put it into bit 3.
                      00128 
0038   2812           00129      goto      MainLoop
0039                  00130 RotateLeft:
